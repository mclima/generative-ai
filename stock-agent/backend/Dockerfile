# Dockerfile for production deployment with pre-downloaded FinBERT model
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Pre-download FinBERT model during build (this caches the model in the image)
RUN python download_models.py

# Expose port
EXPOSE 8000

# Run the application (use shell form to expand $PORT variable)
CMD uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}
